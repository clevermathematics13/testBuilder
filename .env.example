# Google Apps Script Execution API Deployment ID
# Get this by running: npx clasp open
# Then: Deploy > New deployment > API Executable
# Copy the deployment ID that starts with "AKfycb..."
GAS_DEPLOYMENT_ID=AKfycb_REPLACE_WITH_YOUR_ACTUAL_DEPLOYMENT_ID

# Optional: Set to "true" to run against the HEAD version (dev mode)
# GAS_DEV_MODE=true

# Web App URL (for log fetching via doGet — no Execution API needed)
# Get this from: Apps Script editor → Deploy → Manage deployments → Web app URL
GAS_WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
